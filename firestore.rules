rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return false; } // Simplified for this implementation
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidAppointment(data) {
      return data.keys().hasAll(['id', 'serviceName', 'price', 'currency', 'date', 'time', 'firstName', 'lastName', 'email', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.serviceName is string && data.serviceName.size() <= 200
        && data.price is number
        && data.currency is string && data.currency.size() <= 10
        && data.date is string && data.date.size() <= 50
        && data.time is string && data.time.size() <= 50
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.status is string && data.status.size() <= 50
        // Optional fields check type
        && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 50))
        && (!data.keys().hasAny(['paymentMethod']) || (data.paymentMethod is string && data.paymentMethod.size() <= 50))
        && (!data.keys().hasAny(['meetLink']) || (data.meetLink is string && data.meetLink.size() <= 500));
    }

    match /appointments/{appointmentId} {
      allow read: if true; // We'll allow public reads for the demo admin panel
      
      allow create: if isValidId(appointmentId) && isValidAppointment(incoming());
      
      allow update: if isValidId(appointmentId) && isValidAppointment(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );

      allow delete: if isAdmin(); // Only admin can delete
    }
  }
}
